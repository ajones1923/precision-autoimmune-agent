# Precision Autoimmune Intelligence Agent — Environment Variables
# Copy to .env and fill in your values

# Required: Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=sk-ant-...

# Milvus (defaults work for local DGX Spark setup)
AUTO_MILVUS_HOST=localhost
AUTO_MILVUS_PORT=19530

# Ports
AUTO_STREAMLIT_PORT=8531
AUTO_API_PORT=8532

# LLM model (default: claude-sonnet-4-20250514)
AUTO_LLM_MODEL=claude-sonnet-4-20250514

# Optional: API key for FastAPI authentication (empty = no auth)
AUTO_API_KEY=

# CORS origins (comma-separated)
AUTO_CORS_ORIGINS=http://localhost:8080,http://localhost:8531
